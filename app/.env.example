# Cloudflare R2 - bucket meuspoliticos-media
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=meuspoliticos-media
R2_PUBLIC_URL=https://cdn.meuspoliticos.com.br

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# PostgreSQL
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=meuspoliticos_db
POSTGRES_USER=
POSTGRES_PASSWORD=

# Logto
LOGTO_ENDPOINT=
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_COOKIE_SECRET=
LOGTO_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PAINEL_URL=http://localhost:3000

# Pagamentos Asaas
ASAAS_API_KEY=
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=

# Compatibilidade de webhook InfinitePay legado
INFINITEPAY_HANDLE=

# OpenAI
OPENAI_API_KEY=
IA_RESUMO_MAX_GERACOES_DIA=20
