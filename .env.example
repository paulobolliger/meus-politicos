# ============================================================
# Meus Politicos — Template de Variaveis de Ambiente
# ============================================================
# Copie este arquivo para app/.env.local e preencha os valores
# reais com o gestor de senhas do projeto.
#
# Runtime atual:
# - Logto como identidade
# - PostgreSQL direto via pg
# - OpenAI para resumos
# - Resend para e-mail transacional
# - InfinitePay para apoio
# ============================================================

# ============================================================
# Banco de dados direto
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=meuspoliticos_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ============================================================
# URLs dos subdominios
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://app.localhost:3000
NEXT_PUBLIC_PAINEL_URL=http://painel.localhost:3000

# ============================================================
# Logto
# ============================================================
LOGTO_BASE_URL=
LOGTO_ENDPOINT=
LOGTO_APP_ID=
LOGTO_APP_SECRET=<logto-app-secret-placeholder>
# Minimo de 32 caracteres.
LOGTO_COOKIE_SECRET=<logto-cookie-secret-placeholder>

# ============================================================
# Pagamentos
# ============================================================
INFINITEPAY_HANDLE=meus-politicos

# ============================================================
# APIs externas
# ============================================================
OPENAI_API_KEY=
IA_RESUMO_MAX_GERACOES_DIA=3
PORTAL_TRANSPARENCIA_API_KEY=
CRON_SECRET_TOKEN=<chave-secreta-para-orquestrador-n8n>
ETL_RUNNER_POLL_SECONDS=10

# ============================================================
# E-mail transacional
# ============================================================
RESEND_API_KEY=
RESEND_FROM=noreply@meuspoliticos.com.br

